# Core cloud settings
GCP_PROJECT_ID=your_gcp_project_id
BQ_LOCATION=your_bq_location
DBT_DATASET=your_dbt_dataset
GCS_BUCKET=your_gcs_bucket

# Finnhub ingestion settings
FINNHUB_API_KEY=replace_me
RAW_PREFIX=raw
CANDLES_PROVIDER=auto
# FINNHUB_SYMBOLS=AAPL,MSFT,NVDA

# Optional auth override if you use a service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Airflow local settings
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_FIRSTNAME=Data
AIRFLOW_LASTNAME=Engineer
AIRFLOW_EMAIL=airflow@example.com
AIRFLOW_SECRET_KEY=dev-secret-key-change-me
AIRFLOW_FERNET_KEY=
